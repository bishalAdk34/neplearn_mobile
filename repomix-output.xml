import React, { useState, useRef } from 'react';
import { View, Text, Dimensions, Animated, TouchableOpacity } from 'react-native';
import * as Speech from 'expo-speech';
import { useLocalSearchParams, useRouter } from 'expo-router';
import { vocab, getWordsByCategory, shuffle } from '../../src/data/vocab';
import { useVocabStore } from '../../src/data/vocab';

const { width } = Dimensions.get('window');

const Flashcards = () => {
  const { category } = useLocalSearchParams<{ category: string }>();
  const router = useRouter();
  const { toggleLearned, isLearned } = useVocabStore();
  const [words] = useState(shuffle(getWordsByCategory(category)));
  const [currentIndex, setCurrentIndex] = useState(0);
  const [flipped, setFlipped] = useState(false);
  const rotateAnim = useRef(new Animated.Value(0)).current;
  const translateX = useRef(new Animated.Value(0)).current;

  const word = words[currentIndex];

  const flipCard = () => {
    const toValue = flipped ? 0 : 180;
    Animated.spring(rotateAnim, {
      toValue,
      friction: 8,
      tension: 10,
      useNativeDriver: true,
    }).start(() => {
      setFlipped(!flipped);
      if (!flipped) Speech.speak(word.nepali, { language: 'ne-NP' });
    });
  };

  const nextCard = () => {
    if (currentIndex < words.length - 1) {
      setCurrentIndex(currentIndex + 1);
      setFlipped(false);
      rotateAnim.setValue(0);
      translateX.setValue(0);
    } else {
      router.back();
    }
  };

  const swipeRight = () => {
    toggleLearned(word.id);
    nextCard();
  };

  const swipeLeft = () => {
    nextCard();
  };

  if (!word) return <Text className="text-center p-8 text-lg">No words found!</Text>;

  const frontContent = !flipped
    ? word.english
    : `${word.nepali}\n(${word.roman})`;
  const backContent = !flipped
    ? `${word.nepali}\n(${word.roman})`
    : word.english;

  const rotate = rotateAnim.interpolate({
    inputRange: [0, 180],
    outputRange: ['0deg', '180deg'],
  });

  return (
    <View className="flex-1 justify-center items-center p-6">
      <Text className="text-2xl font-bold text-center mb-6 capitalize">{category}</Text>
      <Text className="text-lg text-gray-600 mb-4">{currentIndex + 1} / {words.length}</Text>

      <Animated.View
        style={{ transform: [{ perspective: 1000 }, { rotateY: rotate }] }}
        className="w-full h-72 justify-center items-center bg-white rounded-2xl shadow-xl p-6 mb-8"
      >
        {!flipped ? (
          <>
            <Text className="text-3xl font-bold text-gray-800 text-center">{word.english}</Text>
            <Text className="text-xl text-gray-500 mt-4 text-center">{word.nepali} ({word.roman})</Text>
          </>
        ) : (
          <>
            <Text className="text-3xl font-bold text-gray-800 text-center">{word.nepali}</Text>
            <Text className="text-xl text-gray-500 mt-4 text-center">({word.roman})</Text>
          </>
        )}
      </Animated.View>

      <TouchableOpacity onPress={flipCard} className="bg-blue-500 px-8 py-3 rounded-full mb-6">
        <Text className="text-white font-bold text-lg">{flipped ? 'Show English' : 'Show Nepali'}</Text>
      </TouchableOpacity>

      <View className="flex-row gap-6">
        <TouchableOpacity onPress={swipeLeft} className="bg-red-500 px-8 py-3 rounded-full">
          <Text className="text-white font-bold">Skip</Text>
        </TouchableOpacity>
        <TouchableOpacity onPress={swipeRight} className="bg-green-500 px-8 py-3 rounded-full">
          <Text className="text-white font-bold">Learn</Text>
        </TouchableOpacity>
      </View>
    </View>
  );
};

export default Flashcards;
