<file path="app/index.tsx">
import React from 'react';
import { View, Text, FlatList, TouchableOpacity, ScrollView } from 'react-native';
import { Link } from 'expo-router';
import { categories, getWordsByCategory } from '../src/data/vocab';
import { useVocabStore } from '../src/data/vocab';

const Home = () => {
  const { isLearned } = useVocabStore();

  const renderCategory = ({ item }: { item: string }) => {
    const words = getWordsByCategory(item);
    const learnedCount = words.filter(w => isLearned(w.id)).length;
    const percent = ((learnedCount / words.length) * 100).toFixed(0);

    return (
      <View className="mb-6 p-4 bg-blue-100 rounded-lg">
        <Text className="text-xl font-bold capitalize mb-2">{item}</Text>
        <Text className="text-lg mb-2">Learned: {percent}% ({learnedCount}/{words.length})</Text>
        <View className="flex-row gap-2">
          <Link href={`/flashcards/${item}`} asChild>
            <TouchableOpacity className="flex-1 bg-green-500 p-3 rounded">
              <Text className="text-white font-bold text-center">Flashcards</Text>
            </TouchableOpacity>
          </Link>
          <Link href={`/quiz/${item}`} asChild>
            <TouchableOpacity className="flex-1 bg-purple-500 p-3 rounded">
              <Text className="text-white font-bold text-center">Quiz</Text>
            </TouchableOpacity>
          </Link>
        </View>
      </View>
    );
  };

  return (
    <ScrollView className="flex-1 p-6 bg-gradient-to-b from-blue-50 to-white">
      <Text className="text-3xl font-bold text-center mb-8 text-gray-800">Nepali Learner</Text>
      <FlatList
        data={categories}
        renderItem={renderCategory}
        keyExtractor={(item) => item}
        scrollEnabled={false}
      />
      <Link href="/progress" asChild>
        <TouchableOpacity className="mt-4 bg-indigo-500 p-4 rounded-lg">
          <Text className="text-white font-bold text-center text-lg">Progress</Text>
        </TouchableOpacity>
      </Link>
    </ScrollView>
  );
};

export default Home;
