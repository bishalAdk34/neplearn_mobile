<file path="app/quiz/[category].tsx">
import React, { useState } from 'react';
import { View, Text, TouchableOpacity, Alert } from 'react-native';
import * as Speech from 'expo-speech';
import { useLocalSearchParams, useRouter } from 'expo-router';
import { vocab, getWordsByCategory, shuffle } from '../../src/data/vocab';
import { useVocabStore } from '../../src/data/vocab';

const Quiz = () => {
  const { category } = useLocalSearchParams<{ category: string }>();
  const router = useRouter();
  const { learnWord, isLearned } = useVocabStore();
  const [questions, setQuestions] = useState<any[]>([]);
  const [currentQ, setCurrentQ] = useState(0);
  const [score, setScore] = useState(0);

  React.useEffect(() => {
    const words = shuffle(getWordsByCategory(category)).slice(0, 10);
    const qData = words.map(word => {
      const allNepali = vocab.map(w => w.nepali).filter(n => n !== word.nepali);
      const wrong = shuffle(allNepali).slice(0, 3);
      const options = shuffle([word.nepali, ...wrong]);
      return { ...word, options };
    });
    setQuestions(qData);
  }, [category]);

  const q = questions[currentQ];

  const selectAnswer = (selected: string) => {
    if (selected === q?.nepali) {
      const newScore = score + 1;
      setScore(newScore);
      if (!isLearned(q.id)) learnWord(q.id);
    }
    if (currentQ < questions.length - 1) {
      setCurrentQ(currentQ + 1);
    } else {
      Alert.alert('Quiz Complete!', `Score: ${selected === q?.nepali ? score + 1 : score}/${questions.length}`, [
        { text: 'Home', onPress: () => router.back() },
      ]);
    }
  };

  if (!q) return <Text className="text-center p-8 text-lg">Loading...</Text>;

  return (
    <View className="flex-1 p-6 justify-center">
      <Text className="text-2xl font-bold text-center mb-2 capitalize">{category} Quiz</Text>
      <Text className="text-lg text-gray-600 text-center mb-6">{currentQ + 1} / {questions.length}</Text>
      <TouchableOpacity onPress={() => Speech.speak(q.english, { language: 'en-US' })} className="mb-8">
        <Text className="text-3xl font-bold text-center text-gray-800">{q.english} 🔊</Text>
      </TouchableOpacity>
      <View className="gap-4">
        {q.options.map((opt: string, i: number) => (
          <TouchableOpacity key={i} onPress={() => selectAnswer(opt)} className="p-5 bg-white border rounded-xl shadow-md">
            <Text className="text-xl text-center font-semibold">{opt}</Text>
          </TouchableOpacity>
        ))}
      </View>
      <Text className="text-center mt-8 text-lg">Score: {score}/{currentQ}</Text>
    </View>
  );
};

export default Quiz;
