<file path="app/progress.tsx">
import React from 'react';
import { View, Text, ScrollView, TouchableOpacity } from 'react-native';
import { Link } from 'expo-router';
import { categories, vocab } from '../src/data/vocab';
import { useVocabStore } from '../src/data/vocab';

const Progress = () => {
  const { isLearned } = useVocabStore();

  const stats = categories.map(cat => {
    const words = vocab.filter(w => w.category === cat);
    const learned = words.filter(w => isLearned(w.id)).length;
    return { cat, learned, total: words.length, percent: (learned / words.length * 100).toFixed(0) };
  });

  const totalLearned = stats.reduce((sum, s) => sum + s.learned, 0);
  const totalWords = stats.reduce((sum, s) => sum + s.total, 0);

  return (
    <ScrollView className="flex-1 p-6">
      <Text className="text-3xl font-bold text-center mb-8 text-gray-800">Progress Overview</Text>
      <View className="bg-white p-6 rounded-2xl shadow-lg mb-8">
        <Text className="text-2xl font-bold text-center mb-2">Overall: {totalLearned}/{totalWords}</Text>
        <Text className="text-xl text-center text-green-600">({(totalLearned / totalWords * 100).toFixed(0)}%)</Text>
      </View>
      {stats.map(s => (
        <View key={s.cat} className="bg-white p-6 mb-4 rounded-xl shadow-md">
          <Text className="text-xl font-bold capitalize mb-2">{s.cat}</Text>
          <Text className="text-lg mb-2">{s.learned}/{s.total} learned ({s.percent}%)</Text>
          <Link href={`/flashcards/${s.cat}`} asChild>
            <TouchableOpacity className="bg-blue-500 p-3 rounded-lg">
              <Text className="text-white font-bold text-center">Review {s.cat}</Text>
            </TouchableOpacity>
          </Link>
        </View>
      ))}
    </ScrollView>
  );
};

export default Progress;
