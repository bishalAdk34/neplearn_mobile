import { create } from 'zustand';
import { persist } from 'zustand/middleware';
import AsyncStorage from '@react-native-async-storage/async-storage';
import type { PersistStorage } from 'zustand/middleware';

const asyncStorage: PersistStorage<VocabState> = {
  getItem: async (name) => {
    const val = await AsyncStorage.getItem(name);
    return val ? JSON.parse(val) : null;
  },
  setItem: async (name, value) => {
    await AsyncStorage.setItem(name, JSON.stringify(value));
  },
  removeItem: async (name) => {
    await AsyncStorage.removeItem(name);
  },
};

export type Word = {
  id: number;
  english: string;
  nepali: string;
  roman: string;
  category: string;
};

type VocabState = {
  learned: number[];
  learnWord: (id: number) => void;
  unlearnWord: (id: number) => void;
  isLearned: (id: number) => boolean;
  toggleLearned: (id: number) => void;
};

export const useVocabStore = create<VocabState>()(
  persist(
    (set, get) => ({
      learned: [],
      learnWord: (id) => set({ learned: [...get().learned, id] }),
      unlearnWord: (id) => set({ learned: get().learned.filter(l => l !== id) }),
      isLearned: (id) => get().learned.includes(id),
      toggleLearned: (id) => {
        const learned = get().learned;
        if (learned.includes(id)) {
          set({ learned: learned.filter(l => l !== id) });
        } else {
          set({ learned: [...learned, id] });
        }
      },
    }),
    {
      name: 'nepali-vocab',
      storage: asyncStorage,
    }
  )
);

export const categories = [
  'greetings', 'numbers', 'colors', 'family', 'food',
  'directions', 'days', 'time', 'adjectives', 'places',
] as const;

export type Category = (typeof categories)[number];

